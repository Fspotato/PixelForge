# Django 核心
DJANGO_ENV=stage
DJANGO_SETTINGS_MODULE=config.settings.stage
DJANGO_SECRET_KEY=change-me-stage
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=127.0.0.1,stage-web

# Django 管理員
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=stage-admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me

# PostgreSQL
POSTGRES_DB=ai_service_framework_stage
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@stage-postgres:5432/ai_service_framework_stage

# Redis / Celery
REDIS_URL=redis://stage-redis:6379/0
CELERY_BROKER_URL=redis://stage-redis:6379/1
CELERY_RESULT_BACKEND=redis://stage-redis:6379/2

# 前端與跨站設定
CORS_ALLOWED_ORIGINS=https://your-stage-domain.com
CSRF_TRUSTED_ORIGINS=https://your-stage-domain.com
FRONTEND_URL=https://your-stage-domain.com

# Email（SMTP 真實發信）
# 常見 SMTP 服務設定參考：
#   Gmail:    HOST=smtp.gmail.com     PORT=587  USE_TLS=true  （需開啟應用程式密碼）
#   Outlook:  HOST=smtp.office365.com PORT=587  USE_TLS=true
#   SendGrid: HOST=smtp.sendgrid.net  PORT=587  USE_TLS=true  USER=apikey  PASSWORD=<API Key>
#   Mailgun:  HOST=smtp.mailgun.org   PORT=587  USE_TLS=true
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=noreply@your-stage-domain.com

# Google OAuth
# 需在 Google Cloud Console > OAuth 2.0 用戶端 > 已授權的重新導向 URI 登記：
#   https://your-stage-domain.com/api/v1/auth/social/google/callback/
GOOGLE_CLIENT_ID=
GOOGLE_SECRET_KEY=
SOCIAL_AUTH_CALLBACK_BASE_URL=https://your-stage-domain.com

# 阿里雲百煉平台（DashScope）
# API Key 可從百煉控制台取得：https://bailian.console.aliyun.com/
# Base URL 依地域不同：
#   新加坡:         https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   美國（維吉尼亞）: https://dashscope-us.aliyuncs.com/compatible-mode/v1
#   中國北京:        https://dashscope.aliyuncs.com/compatible-mode/v1
#   中國香港:        https://cn-hongkong.dashscope.aliyuncs.com/compatible-mode/v1
ALIBABA_BAILIAN_API_KEY=
ALIBABA_BAILIAN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# 逗號分隔的可用模型清單（第一個為預設模型，可自行增減）
ALIBABA_BAILIAN_TEXT_MODELS=qwen-plus,qwen-max,qwen-turbo,qwen3.5-plus,qwen3.5-turbo,qwen-long
ALIBABA_BAILIAN_IMAGE_MODELS=wanx2.1-t2i-plus,wanx2.1-t2i-turbo

# Logger
LOGGER_ENABLE_MIDDLEWARE_LOGS=true
